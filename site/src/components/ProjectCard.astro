---
/**
 * One project as a clickable card: name + category, tl;dr summary,
 * first four stack chips, honest metric chips.
 */
import { t, localePath } from "../lib/i18n.js";
import type { ProjectData } from "../lib/data.js";
import CategoryBadge from "./CategoryBadge.astro";
import TechStackList from "./TechStackList.astro";
import MetricChips from "./MetricChips.astro";

interface Props {
  project: ProjectData;
  locale: string;
  sourceLang: string;
  defaultLocale: string;
}

const { project, locale, sourceLang, defaultLocale } = Astro.props;
const href = localePath(`/projects/${project.id}`, locale, defaultLocale);
const summary = t(project.summary, locale, sourceLang);
---

<a class="card project-card" href={href} data-reveal>
  <div class="head">
    <h3 class="name">{project.name}</h3>
    <CategoryBadge category={project.category} locale={locale} />
  </div>
  {summary && <p class="summary">{summary}</p>}
  <TechStackList techStack={project.techStack} max={4} />
  <MetricChips project={project} locale={locale} />
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.25rem;
    color: var(--text);
    transition:
      border-color 150ms ease,
      transform 150ms ease;
  }
  .project-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    text-decoration: none;
  }
  .head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .name {
    margin: 0;
    font-size: 1.05rem;
  }
  .summary {
    margin: 0;
    color: var(--text-dim);
    font-size: 0.92rem;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
