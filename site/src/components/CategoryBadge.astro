---
/**
 * Small chip labeling the project category with a per-category accent dot.
 * Labels live in the shared UI dictionary (site/src/lib/i18n.ts).
 */
import { ui } from "../lib/i18n";

interface Props {
  category: string;
  locale: string;
}

const { category, locale } = Astro.props;

const key = `category.${category}`;
const resolved = ui(key, locale);
const label = resolved === key ? category : resolved;
---

<span class:list={["chip", "category-badge", `cat-${category}`]}>
  <span class="dot" aria-hidden="true"></span>{label}
</span>

<style>
  .category-badge {
    align-items: center;
    gap: 0.45em;
  }
  .dot {
    inline-size: 0.5em;
    block-size: 0.5em;
    border-radius: 50%;
    background: var(--text-faint);
    flex: none;
  }
  .cat-product .dot,
  .cat-service .dot {
    background: var(--accent);
  }
  .cat-client .dot {
    background: var(--warn);
  }
  .cat-oss .dot,
  .cat-hobby .dot {
    background: var(--ok);
  }
  .cat-learning .dot {
    background: var(--text-faint);
  }
</style>
