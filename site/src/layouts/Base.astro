---
/**
 * Shared page shell — SEO/hreflang plumbing, a11y skeleton, theme token
 * injection, and motion boot. The look lives in the active theme package
 * ("@theme" alias, selected in site/theme.config.mjs): the theme owns the
 * Header/Footer components, its stylesheet, and every token value.
 *
 * `surface` marks the page as the expressive "showcase" surface (home) or
 * the calm "read" surface (everything else); themes scope wilder rules
 * under body[data-surface="showcase"].
 */
import { ClientRouter } from "astro:transitions";
import { theme } from "@theme/tokens";
import Header from "@theme/components/Header.astro";
import Footer from "@theme/components/Footer.astro";
import "@theme/styles.css";
import { cssVarsFor, fontFacesFor } from "../lib/theme-css.js";
import { t, localePath } from "../lib/i18n.js";
import { getProfile } from "../lib/data.js";
import "../styles/global.css";

interface Props {
  locale: string;
  title?: string;
  description?: string;
  /** Path WITHOUT locale prefix, e.g. "/projects/foo" — used for hreflang + switcher */
  path: string;
  ogImage?: string;
  surface?: "showcase" | "read";
}

const { locale, title, description, path, ogImage, surface = "read" } = Astro.props;
const profile = await getProfile();
const sl = profile.sourceLang;
const defaultLocale = sl;
const locales = [sl, ...profile.targetLangs];

const pageTitle = title ? `${title} — ${profile.name}` : profile.seo.title;
const pageDesc = description ?? t(profile.seo.description, locale, sl);
const lp = (p: string) => localePath(p, locale, defaultLocale);

const site = Astro.site?.href?.replace(/\/$/, "") ?? "";
const fontFaces = fontFacesFor(theme);
const fontPreloads = (theme.webfonts ?? []).filter((f) => f.preload);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={`${site}${lp(path)}`} />
    {
      locales.map((l) => (
        <link
          rel="alternate"
          hreflang={l}
          href={`${site}${localePath(path, l, defaultLocale)}`}
        />
      ))
    }
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${site}${lp(path)}`} />
    {ogImage && <meta property="og:image" content={`${site}${ogImage}`} />}
    {ogImage && <meta name="twitter:card" content="summary_large_image" />}
    {
      fontPreloads.map((f) => (
        <link
          rel="preload"
          href={`/fonts/${f.file}`}
          as="font"
          type="font/woff2"
          crossorigin
        />
      ))
    }
    <style set:html={`:root{${cssVarsFor(theme)}}`}></style>
    {fontFaces && <style set:html={fontFaces}></style>}
    <ClientRouter />
    <script>
      // Site-wide scroll polish (Lenis + GSAP reveals). No-ops itself under
      // prefers-reduced-motion; re-inits across View Transitions.
      import { initMotion, destroyMotion } from "../scripts/motion.js";
      initMotion();
      document.addEventListener("astro:page-load", () => initMotion());
      document.addEventListener("astro:before-swap", () => destroyMotion());
    </script>
    {
      profile.analytics?.cloudflareToken && (
        <script
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${profile.analytics.cloudflareToken}"}`}
        />
      )
    }
  </head>
  <body data-surface={surface}>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header locale={locale} path={path} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
