---
import { ClientRouter } from "astro:transitions";
import { themeCssVars } from "../theme.js";
import { t, ui, localePath, languageLabel } from "../lib/i18n.js";
import { getProfile, getAggregates, showHistoryPage } from "../lib/data.js";
import "../styles/global.css";

interface Props {
  locale: string;
  title?: string;
  description?: string;
  /** Path WITHOUT locale prefix, e.g. "/projects/foo" — used for hreflang + switcher */
  path: string;
  ogImage?: string;
}

const { locale, title, description, path, ogImage } = Astro.props;
const profile = await getProfile();
const aggregates = await getAggregates();
const sl = profile.sourceLang;
const defaultLocale = sl;
const locales = [sl, ...profile.targetLangs];

const pageTitle = title ? `${title} — ${profile.name}` : profile.seo.title;
const pageDesc = description ?? t(profile.seo.description, locale, sl);
const lp = (p: string) => localePath(p, locale, defaultLocale);
const historyVisible = showHistoryPage(aggregates);

const nav = [
  { href: lp("/projects"), label: ui("nav.projects", locale) },
  ...(historyVisible ? [{ href: lp("/history"), label: ui("nav.history", locale) }] : []),
  { href: lp("/about"), label: ui("nav.about", locale) },
  { href: lp("/overview"), label: ui("nav.overview", locale) },
];

const site = Astro.site?.href?.replace(/\/$/, "") ?? "";
const otherLocales = locales.filter((l) => l !== locale);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={`${site}${lp(path)}`} />
    {
      locales.map((l) => (
        <link
          rel="alternate"
          hreflang={l}
          href={`${site}${localePath(path, l, defaultLocale)}`}
        />
      ))
    }
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${site}${lp(path)}`} />
    {ogImage && <meta property="og:image" content={`${site}${ogImage}`} />}
    {ogImage && <meta name="twitter:card" content="summary_large_image" />}
    <style set:html={`:root{${themeCssVars()}}`}></style>
    <ClientRouter />
    <script>
      // Site-wide scroll polish (Lenis + GSAP reveals). No-ops itself under
      // prefers-reduced-motion; re-inits across View Transitions.
      import { initMotion, destroyMotion } from "../scripts/motion.js";
      initMotion();
      document.addEventListener("astro:page-load", () => initMotion());
      document.addEventListener("astro:before-swap", () => destroyMotion());
    </script>
    {
      profile.analytics?.cloudflareToken && (
        <script
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${profile.analytics.cloudflareToken}"}`}
        />
      )
    }
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header class="site-header">
      <div class="container header-inner">
        <a href={lp("/")} class="brand">{profile.name}</a>
        <nav aria-label="primary">
          {nav.map((item) => <a href={item.href}>{item.label}</a>)}
          {
            otherLocales.map((l) => (
              <a
                href={localePath(path, l, defaultLocale)}
                class="lang-switch"
                aria-label={`Switch language to ${languageLabel(l)}`}
              >
                {languageLabel(l)}
              </a>
            ))
          }
        </nav>
      </div>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-inner">
        <span>© {new Date().getFullYear()} {profile.name}</span>
        <span class="footer-socials">
          {profile.socials.map((s) => <a href={s.url} rel="me noopener">{s.platform}</a>)}
        </span>
        <span class="footer-note">{ui("footer.builtWith", locale)}</span>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.5rem;
  }
  .brand {
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
  }
  .brand:hover {
    text-decoration: none;
    color: var(--accent);
  }
  nav {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }
  nav a {
    color: var(--text-dim);
    font-size: 0.92rem;
  }
  nav a:hover {
    color: var(--text);
    text-decoration: none;
  }
  .lang-switch {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.1rem 0.7rem;
    font-size: 0.8rem;
  }
  .site-footer {
    border-top: 1px solid var(--line);
    margin-top: 6rem;
    padding: 2rem 0;
    color: var(--text-faint);
    font-size: 0.85rem;
  }
  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: space-between;
  }
  .footer-socials {
    display: flex;
    gap: 1rem;
  }
  .footer-note {
    opacity: 0.7;
  }
</style>
