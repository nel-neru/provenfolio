---
/**
 * Shared page shell — SEO/hreflang plumbing, a11y skeleton, theme token
 * injection, motion boot, and the visitor design switcher. The look lives
 * in theme packages (site/src/themes/<name>/), resolved through the
 * registry: root URLs render the active theme (theme.config.mjs), and the
 * prerendered /t/<theme>/ trees render every visitor-exposed theme — the
 * `theme` route param, visible here via Astro.params, selects it with no
 * prop threading. Dynamic manifest loading keeps each built page's CSS
 * scoped to its own theme.
 *
 * `surface` marks the page as the expressive "showcase" surface (home) or
 * the calm "read" surface (everything else); themes scope wilder rules
 * under body[data-surface="showcase"].
 */
import { ClientRouter } from "astro:transitions";
import { cssVarsFor, fontFacesFor } from "../lib/theme-css.js";
import {
  getManifest,
  listVisitorThemes,
  activeTheme,
} from "../lib/theme-registry.js";
import { t, ui, localePath } from "../lib/i18n.js";
import { getProfile } from "../lib/data.js";
import "../styles/global.css";

interface Props {
  locale: string;
  title?: string;
  description?: string;
  /** Path WITHOUT locale prefix, e.g. "/projects/foo" — used for hreflang + switcher */
  path: string;
  ogImage?: string;
  surface?: "showcase" | "read";
}

const { locale, title, description, path, ogImage, surface = "read" } = Astro.props;

// Under /t/[theme]/ routes the param selects the theme; everywhere else
// the active theme renders. Child components see the same params object.
const themeParam = (Astro.params as { theme?: string } | undefined)?.theme;
const themeName = themeParam ?? activeTheme;
const isOverride = themeParam !== undefined;
const manifest = await getManifest(themeName);
const tokens = manifest.tokens;
const Header = manifest.components.Header;
const Footer = manifest.components.Footer;

const profile = await getProfile();
const sl = profile.sourceLang;
const defaultLocale = sl;
const locales = [sl, ...profile.targetLangs];

const pageTitle = title ? `${title} — ${profile.name}` : profile.seo.title;
const pageDesc = description ?? t(profile.seo.description, locale, sl);
const lp = (p: string) => localePath(p, locale, defaultLocale);

const site = Astro.site?.href?.replace(/\/$/, "") ?? "";
const fontFaces = fontFacesFor(tokens);
const fontPreloads = (tokens.webfonts ?? []).filter((f) => f.preload);

// Visitor design switcher. The active theme is always offered first (it
// links to the indexed root URLs), followed by the configured alternates —
// so a visitor can always get back to the live design even when
// visitorThemes is an explicit array that omits it. Hidden below two entries.
const visitorList = [
  activeTheme,
  ...listVisitorThemes().filter((name) => name !== activeTheme),
];
const showSwitcher = visitorList.length >= 2;
const logicalPath = lp(path);
const themeHref = (name: string) =>
  name === activeTheme ? logicalPath : `/t/${name}${logicalPath}`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta name="generator" content={Astro.generator} />
    {isOverride && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={`${site}${logicalPath}`} />
    {
      locales.map((l) => (
        <link
          rel="alternate"
          hreflang={l}
          href={`${site}${localePath(path, l, defaultLocale)}`}
        />
      ))
    }
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${site}${logicalPath}`} />
    {ogImage && <meta property="og:image" content={`${site}${ogImage}`} />}
    {ogImage && <meta name="twitter:card" content="summary_large_image" />}
    {
      fontPreloads.map((f) => (
        <link
          rel="preload"
          href={`/fonts/${f.file}`}
          as="font"
          type="font/woff2"
          crossorigin
        />
      ))
    }
    <style set:html={`:root{${cssVarsFor(tokens)}}`}></style>
    {fontFaces && <style set:html={fontFaces}></style>}
    <ClientRouter />
    <script>
      // Site-wide scroll polish (Lenis + GSAP reveals). No-ops itself under
      // prefers-reduced-motion; re-inits across View Transitions.
      import { initMotion, destroyMotion } from "../scripts/motion.js";
      initMotion();
      document.addEventListener("astro:page-load", () => initMotion());
      document.addEventListener("astro:before-swap", () => destroyMotion());
    </script>
    {
      profile.analytics?.cloudflareToken && (
        <script
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${profile.analytics.cloudflareToken}"}`}
        />
      )
    }
  </head>
  <body data-surface={surface} data-theme={themeName}>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header locale={locale} path={path} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
    {
      showSwitcher && (
        <nav class="theme-dock no-print" aria-label={ui("theme.switcher", locale)}>
          <details>
            <summary>
              <span class="dock-label">{ui("theme.switcher", locale)}</span>
              <span class="dock-current">{themeName}</span>
            </summary>
            <ul role="list">
              {visitorList.map((name) => (
                <li>
                  <a
                    href={themeHref(name)}
                    data-theme-link
                    aria-current={name === themeName ? "page" : undefined}
                  >
                    {name}
                  </a>
                </li>
              ))}
            </ul>
          </details>
        </nav>
      )
    }
    {
      isOverride && (
        <script is:inline>
          /* Keep in-site links inside the current /t/<theme>/ tree. Reads
             the prefix from the URL each run, so stale listeners left by
             View Transitions can never mis-prefix root pages. */
          if (!window.__themePrefixer) {
            window.__themePrefixer = true;
            const rewrite = () => {
              const m = location.pathname.match(/^\/t\/([^/]+)(?=\/|$)/);
              if (!m) return;
              const prefix = m[0];
              document.querySelectorAll('a[href^="/"]').forEach((a) => {
                const href = a.getAttribute("href");
                if (!href || href.startsWith("/t/") || a.hasAttribute("data-theme-link")) return;
                a.setAttribute("href", prefix + href);
              });
            };
            rewrite();
            document.addEventListener("astro:page-load", rewrite);
          }
        </script>
      )
    }
  </body>
</html>

<style>
  .theme-dock {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 60;
    font-size: 0.8rem;
    font-family: var(--font-mono);
  }
  .theme-dock summary {
    list-style: none;
    cursor: pointer;
    display: inline-flex;
    align-items: baseline;
    gap: 0.45em;
    padding: 0.35rem 0.8rem;
    background: var(--bg-raised);
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--text-dim);
  }
  .theme-dock summary::-webkit-details-marker {
    display: none;
  }
  .theme-dock summary:hover {
    border-color: var(--accent);
    color: var(--text);
  }
  .dock-label {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.68em;
    color: var(--text-faint);
  }
  .dock-current {
    color: var(--accent);
  }
  .theme-dock ul {
    position: absolute;
    right: 0;
    bottom: calc(100% + 0.4rem);
    margin: 0;
    padding: 0.35rem;
    list-style: none;
    min-width: 11rem;
    background: var(--bg-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    display: grid;
    gap: 0.1rem;
  }
  .theme-dock ul a {
    display: block;
    padding: 0.3rem 0.7rem;
    border-radius: var(--radius-sm);
    color: var(--text-dim);
  }
  .theme-dock ul a:hover {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--text);
    text-decoration: none;
  }
  .theme-dock ul a[aria-current="page"] {
    color: var(--accent);
  }
</style>
