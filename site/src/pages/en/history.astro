---
import HistoryPage from "@theme/components/HistoryPage.astro";
import { localePath } from "../../lib/i18n.js";
import { getProfile, getAggregates, showHistoryPage } from "../../lib/data.js";

const profile = await getProfile();
const aggregates = await getAggregates();

// Density gate — same condition that hides the History nav link. While the
// gate is closed the page must not ship at all: emit a build-time redirect
// stub to the home page (Astro renders it with noindex + canonical) instead
// of exposing the sparse placeholder to direct URL hits.
if (!showHistoryPage(aggregates))
  return Astro.redirect(localePath("/", "en", profile.sourceLang), 307);
---

<HistoryPage locale="en" />
