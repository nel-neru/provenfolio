---
import { getManifest, listPrerenderThemes } from "../../../../lib/theme-registry.js";
import { targetLocales } from "../../../../lib/i18n.js";
import { getProfile } from "../../../../lib/data.js";

export async function getStaticPaths() {
  const profile = await getProfile();
  return listPrerenderThemes().flatMap((theme) =>
    targetLocales(profile).map((lang) => ({ params: { theme, lang } }))
  );
}

const { AboutPage } = (await getManifest(Astro.params.theme!)).components;
---

<AboutPage locale={Astro.params.lang!} />
