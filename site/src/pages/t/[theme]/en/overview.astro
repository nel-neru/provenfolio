---
import { getManifest, listPrerenderThemes } from "../../../../lib/theme-registry.js";

export function getStaticPaths() {
  return listPrerenderThemes().map((theme) => ({ params: { theme } }));
}

const { OverviewPage } = (await getManifest(Astro.params.theme!)).components;
---

<OverviewPage locale="en" />
