---
import { getManifest, listPrerenderThemes } from "../../../../lib/theme-registry.js";
import { getProfile } from "../../../../lib/data.js";

export function getStaticPaths() {
  return listPrerenderThemes().map((theme) => ({ params: { theme } }));
}

const profile = await getProfile();
const { ProjectsPage } = (await getManifest(Astro.params.theme!)).components;
---

<ProjectsPage locale={profile.sourceLang} />
