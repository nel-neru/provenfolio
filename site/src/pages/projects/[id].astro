---
import ProjectPage from "@theme/components/ProjectPage.astro";
import { getProfile, getProjects } from "../../lib/data.js";
import type { ProjectData } from "../../lib/data.js";

export async function getStaticPaths() {
  const projects = await getProjects();
  return projects.map((p) => ({ params: { id: p.id }, props: { project: p } }));
}

interface Props {
  project: ProjectData;
}

const { project } = Astro.props;
const profile = await getProfile();
---

<ProjectPage locale={profile.sourceLang} project={project} />
