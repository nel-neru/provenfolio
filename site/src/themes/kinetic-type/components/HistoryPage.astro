---
/**
 * Cross-project history — midnight's density-gated logic (sparse branch:
 * honest note + oldest-first cards; full branch: span chart + yearly
 * chips + adoption note) restyled as a specimen sheet: square 0-radius
 * span bars on ruled tracks, mono tabular year labels, pill year chips.
 */
import Base from "../../../layouts/Base.astro";
import ProjectCard from "../../../components/ProjectCard.astro";
import { ui, localePath } from "../../../lib/i18n.js";
import {
  getProfile,
  getAggregates,
  getProjects,
  showHistoryPage,
} from "../../../lib/data.js";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const profile = await getProfile();
const sl = profile.sourceLang;
const defaultLocale = sl;
const aggregates = await getAggregates();
const visible = showHistoryPage(aggregates);

// Sparse branch: all projects, oldest first (still useful).
const projects = await getProjects();
const byFirstCommit = [...projects].sort((a, b) =>
  (a.metrics?.total.firstCommit ?? "9999").localeCompare(
    b.metrics?.total.firstCommit ?? "9999"
  )
);

// Full branch: span bars across the min..max commit range.
const DAY = 86_400_000;
const spans = (aggregates?.projectSpans ?? []).filter(
  (s) => s.firstCommit && s.lastCommit
);
const minT = spans.length
  ? Math.min(...spans.map((s) => Date.parse(s.firstCommit!)))
  : 0;
const maxT = spans.length
  ? Math.max(...spans.map((s) => Date.parse(s.lastCommit!)))
  : 0;
const range = Math.max(maxT - minT, DAY);

const rows = spans.map((s) => ({
  id: s.id,
  name: s.name,
  placement: s.placement,
  commits: s.commits,
  first: s.firstCommit!,
  last: s.lastCommit!,
  left: ((Date.parse(s.firstCommit!) - minT) / range) * 100,
  width: Math.max(
    ((Date.parse(s.lastCommit!) - Date.parse(s.firstCommit!)) / range) * 100,
    1.5
  ),
}));

// Year gridlines: Jan 1 of each year inside the range.
const years: Array<{ year: number; left: number }> = [];
if (spans.length) {
  for (
    let y = new Date(minT).getUTCFullYear() + 1;
    y <= new Date(maxT).getUTCFullYear();
    y++
  ) {
    const t = Date.parse(`${y}-01-01T00:00:00Z`);
    if (t >= minT && t <= maxT) years.push({ year: y, left: ((t - minT) / range) * 100 });
  }
}

const yearly = aggregates?.yearlyActivity ?? [];
// Tech adoption note, ordered by first use.
const adoption = (aggregates?.techFrequency ?? [])
  .filter((t) => t.firstUsed)
  .sort((a, b) => a.firstUsed!.localeCompare(b.firstUsed!));
---

<Base locale={locale} title={ui("history.title", locale)} path="/history">
  <div class="container page">
    <h1 class="page-title">{ui("history.title", locale)}</h1>

    {
      !visible ? (
        <>
          <p class="empty-note">{ui("history.empty", locale)}</p>
          <div class="grid">
            {byFirstCommit.map((p) => (
              <ProjectCard
                project={p}
                locale={locale}
                sourceLang={sl}
                defaultLocale={defaultLocale}
              />
            ))}
          </div>
        </>
      ) : (
        <>
          <section class="block">
            <div class="span-chart">
              {years.map((y) => (
                <span class="year-line" style={`left:${y.left}%`} aria-hidden="true">
                  <span class="year-label mono">{y.year}</span>
                </span>
              ))}
              {rows.map((r) => (
                <div class="span-row">
                  <a
                    class="span-name"
                    href={localePath(`/projects/${r.id}`, locale, defaultLocale)}
                  >
                    {r.name}
                  </a>
                  <div class="track">
                    <span
                      class:list={["bar", `pl-${r.placement}`]}
                      style={`left:${r.left}%;width:${r.width}%`}
                      title={`${r.first} — ${r.last}`}
                    />
                  </div>
                </div>
              ))}
            </div>
          </section>

          {yearly.length > 0 && (
            <section class="block">
              <div class="year-chips">
                {yearly.map((y) => (
                  <span class="chip">
                    <b>{y.year}</b> {y.commits} {ui("metrics.commits", locale)} ·{" "}
                    {y.activeDays} {ui("metrics.activeDays", locale)}
                  </span>
                ))}
              </div>
            </section>
          )}

          {adoption.length > 0 && (
            <section class="block">
              <p class="adoption">
                {adoption.map((t, i) => (
                  <span class="adoption-item">
                    {i > 0 && <span class="adoption-sep" aria-hidden="true"> · </span>}
                    {t.name}
                    <span class="since mono">{t.firstUsed!.slice(0, 4)}~</span>
                  </span>
                ))}
              </p>
            </section>
          )}
        </>
      )
    }
  </div>
</Base>

<style>
  .page {
    padding-top: 7rem;
  }
  .page-title {
    margin: 0 0 var(--space-4, 2rem);
    font-family: var(--font-display, var(--font-sans));
    font-size: clamp(2.75rem, 8vw, 6rem);
    font-weight: 900;
    font-variation-settings: "wght" 900, "wdth" 102;
    line-height: 0.9;
    letter-spacing: -0.03em;
    text-transform: uppercase;
  }
  .page-title::after {
    content: ".";
    color: var(--accent);
  }
  .empty-note {
    color: var(--text-dim);
    margin: 0 0 var(--space-4, 2rem);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }
  .block + .block {
    margin-top: var(--space-4, 2rem);
  }
  .span-chart {
    position: relative;
    display: grid;
    gap: 0.9rem;
    padding-block: 1.7rem 0.5rem;
    border-top: 1px solid var(--line);
  }
  .year-line {
    position: absolute;
    top: 0;
    bottom: 0;
    border-left: 1px dashed var(--line);
  }
  .year-label {
    position: absolute;
    top: 0.3rem;
    left: 0.35rem;
    font-size: 0.7rem;
    color: var(--text-faint);
    font-variant-numeric: tabular-nums;
  }
  .span-row {
    display: grid;
    grid-template-columns: minmax(8rem, 14rem) 1fr;
    align-items: center;
    gap: 1rem;
  }
  .span-name {
    font-size: var(--text-sm, 0.875rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .span-name:hover,
  .span-name:focus-visible {
    color: var(--accent-lift);
    text-decoration: none;
  }
  .track {
    position: relative;
    height: 10px;
    background: var(--bg-raised);
    border: 1px solid var(--line);
  }
  .bar {
    position: absolute;
    top: 0;
    bottom: 0;
    background: var(--text-faint);
  }
  .pl-products {
    background: var(--accent);
  }
  .pl-lab {
    background: var(--ok);
  }
  .pl-archive {
    background: var(--text-faint);
  }
  .year-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .adoption {
    margin: 0;
    color: var(--text-dim);
    font-size: var(--text-sm, 0.875rem);
    line-height: 2;
  }
  .since {
    color: var(--text-faint);
    font-size: 0.78em;
    margin-left: 0.35em;
  }
  @media (max-width: 720px) {
    .page {
      padding-top: 6rem;
    }
  }
</style>
