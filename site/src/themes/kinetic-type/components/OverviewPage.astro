---
/**
 * Overview — the recruiter one-pager, unchanged in content and logic from
 * midnight: compact header, one tight card per non-archive project, honest
 * metric chips, top-3 stack, demo link. Screen styling gets the mono
 * poster voice at low amplitude; print output stays dense and ink-friendly
 * (white ground, dark text, no decoration).
 */
import Base from "../../../layouts/Base.astro";
import CategoryBadge from "../../../components/CategoryBadge.astro";
import TechStackList from "../../../components/TechStackList.astro";
import MetricChips from "../../../components/MetricChips.astro";
import { t, ui, localePath } from "../../../lib/i18n.js";
import { getProfile, getProjects } from "../../../lib/data.js";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const profile = await getProfile();
const sl = profile.sourceLang;
const defaultLocale = sl;
const projects = (await getProjects()).filter((p) => p.placement !== "archive");

const DEMO_KINDS = ["demo", "store", "video"];
const demoLink = (p: (typeof projects)[number]) =>
  p.links.find((l) => DEMO_KINDS.includes(l.kind));
---

<Base locale={locale} title={ui("overview.title", locale)} path="/overview">
  <div class="container page">
    <p class="note mono">{ui("overview.note", locale)}</p>

    <header class="head">
      <h1 class="name">{profile.name}</h1>
      <p class="line kicker mono">
        {t(profile.role, locale, sl)}
        <span class="sep" aria-hidden="true">—</span>
        {t(profile.tagline, locale, sl)}
      </p>
      {profile.socials.length > 0 && <p class="socials">
        {
          profile.socials.map((s) => (
            <a href={s.url} rel="me noopener">
              {s.platform}
            </a>
          ))
        }
        {profile.email && <a href={`mailto:${profile.email}`}>{profile.email}</a>}
      </p>}
    </header>

    <div class="stack">
      {
        projects.map((p) => {
          const demo = demoLink(p);
          return (
            <article class="card ov-card">
              <div class="row">
                <h2 class="p-name">
                  <a href={localePath(`/projects/${p.id}`, locale, defaultLocale)}>
                    {p.name}
                  </a>
                </h2>
                <CategoryBadge category={p.category} locale={locale} />
                {demo && (
                  <a class="demo mono" href={demo.url} target="_blank" rel="noopener">
                    {t(demo.label, locale, sl) || demo.kind} ↗
                  </a>
                )}
              </div>
              <p class="p-summary">{t(p.summary, locale, sl)}</p>
              <div class="row meta">
                <MetricChips project={p} locale={locale} />
                <TechStackList techStack={p.techStack} max={3} />
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</Base>

<style>
  .page {
    padding-top: 6.5rem;
  }
  .note {
    margin: 0 0 1.5rem;
    color: var(--text-faint);
  }
  .note::before {
    content: "/ ";
    color: var(--accent);
  }
  .head {
    margin-bottom: var(--space-4, 2rem);
    border-bottom: 1px solid var(--line);
    padding-bottom: 1.4rem;
  }
  .name {
    margin: 0;
    font-family: var(--font-display, var(--font-sans));
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 900;
    font-variation-settings: "wght" 900, "wdth" 102;
    letter-spacing: -0.02em;
    line-height: 1;
    text-transform: uppercase;
  }
  .name::after {
    content: ".";
    color: var(--accent);
  }
  .line {
    margin: 0.6rem 0 0;
  }
  .socials {
    margin: 0.6rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: var(--text-sm, 0.875rem);
  }
  .socials a {
    color: var(--text-dim);
  }
  .socials a:hover,
  .socials a:focus-visible {
    color: var(--accent-lift);
    text-decoration: none;
  }
  .stack {
    display: grid;
    gap: 0.75rem;
  }
  .ov-card {
    padding: 1rem 1.2rem;
    display: grid;
    gap: 0.55rem;
  }
  .row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .p-name {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 900;
    letter-spacing: -0.01em;
    text-transform: uppercase;
  }
  .p-name a {
    color: var(--text);
  }
  .p-name a:hover,
  .p-name a:focus-visible {
    color: var(--accent-lift);
    text-decoration: none;
  }
  .demo {
    margin-left: auto;
    border: 1px solid var(--accent);
    color: var(--accent-lift);
    padding: 0.15rem 0.7rem;
  }
  .demo:hover,
  .demo:focus-visible {
    text-decoration: none;
    background: var(--accent-soft);
  }
  .p-summary {
    margin: 0;
    color: var(--text-dim);
    font-size: var(--text-sm, 0.875rem);
    line-height: 1.6;
    max-width: 70ch;
  }
  .meta {
    row-gap: 0.4rem;
  }

  /* Print: dense, ink-friendly, no decoration (global rules already hide
     header/footer and set the white background). */
  @media print {
    .page {
      padding-top: 0;
    }
    .note {
      display: none;
    }
    .head {
      border-color: #ccc;
    }
    .name,
    .line,
    .p-name a,
    .p-summary {
      color: #111;
    }
    .name::after {
      color: #111;
    }
    .ov-card {
      break-inside: avoid;
      border: 1px solid #ccc;
      background: #fff;
    }
    .socials a,
    .demo {
      color: #111;
      border-color: #999;
    }
    a {
      text-decoration: none;
    }
    .ov-card :global(.chip) {
      background: #fff;
      color: #333;
      border-color: #ccc;
    }
    .ov-card :global(.chip b) {
      color: #111;
    }
    .ov-card :global(.chip.category-badge) {
      background: #fff;
      color: #333;
    }
    .ov-card :global(.chip.category-badge .dot) {
      background: #333;
    }
  }
</style>
