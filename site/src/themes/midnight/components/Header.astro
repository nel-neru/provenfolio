---
/**
 * Midnight header — sticky translucent bar with brand, primary nav, and
 * the language switcher. Theme-owned: other themes may restructure the
 * navigation entirely.
 */
import { ui, localePath, languageLabel } from "../../../lib/i18n.js";
import { getProfile, getAggregates, showHistoryPage } from "../../../lib/data.js";

interface Props {
  locale: string;
  /** Path WITHOUT locale prefix, e.g. "/projects/foo" — for the switcher. */
  path: string;
}

const { locale, path } = Astro.props;
const profile = await getProfile();
const aggregates = await getAggregates();
const defaultLocale = profile.sourceLang;
const locales = [profile.sourceLang, ...profile.targetLangs];
const lp = (p: string) => localePath(p, locale, defaultLocale);
const historyVisible = showHistoryPage(aggregates);

const nav = [
  { path: "/projects", label: ui("nav.projects", locale) },
  ...(historyVisible ? [{ path: "/history", label: ui("nav.history", locale) }] : []),
  { path: "/about", label: ui("nav.about", locale) },
  { path: "/overview", label: ui("nav.overview", locale) },
];

const otherLocales = locales.filter((l) => l !== locale);
---

<header class="site-header">
  <div class="container header-inner">
    <a href={lp("/")} class="brand">{profile.name}</a>
    <nav aria-label="primary">
      {
        nav.map((item) => (
          <a href={lp(item.path)} aria-current={path === item.path ? "page" : undefined}>
            {item.label}
          </a>
        ))
      }
      {
        otherLocales.map((l) => (
          <a
            href={localePath(path, l, defaultLocale)}
            class="lang-switch"
            aria-label={languageLabel(l)}
          >
            {languageLabel(l)}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.25rem 1rem;
    min-height: 3.5rem;
    padding-block: 0.4rem;
  }
  .brand {
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
  }
  .brand:hover {
    text-decoration: none;
    color: var(--accent);
  }
  nav {
    display: flex;
    gap: 0.5rem 1.25rem;
    align-items: center;
    flex-wrap: wrap;
  }
  nav a {
    color: var(--text-dim);
    font-size: 0.92rem;
  }
  nav a:hover {
    color: var(--text);
    text-decoration: none;
  }
  nav a[aria-current="page"] {
    color: var(--text);
  }
  .lang-switch {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.1rem 0.7rem;
    font-size: 0.8rem;
  }

  @media (max-width: 480px) {
    nav {
      gap: 0.35rem 0.85rem;
    }
    nav a {
      font-size: 0.85rem;
    }
    .lang-switch {
      padding: 0.1rem 0.55rem;
    }
  }
</style>
