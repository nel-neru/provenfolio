---
/**
 * Acid-lab case-study page — the product's centerpiece as a lab specimen
 * sheet. A mono spec kicker + display-face title, sticker category/role,
 * primary/secondary mono buttons, evidence-linked highlight cards, the
 * turning-point timeline, the density-gated metrics viz (never an empty box:
 * the honest chip row renders when nothing qualifies), a window-framed
 * architecture diagram, and screenshots. Data access, link ordering, and the
 * show*() density gates are unchanged from the structural reference.
 */
import Base from "../../../layouts/Base.astro";
import CategoryBadge from "../../../components/CategoryBadge.astro";
import TechStackList from "../../../components/TechStackList.astro";
import MetricChips from "../../../components/MetricChips.astro";
import EvidenceLink from "../../../components/EvidenceLink.astro";
import CaseStudy from "../../../components/CaseStudy.astro";
import Screenshots from "../../../components/Screenshots.astro";
import Timeline from "../../../components/viz/Timeline.astro";
import ContributionHeatmap from "../../../components/viz/ContributionHeatmap.astro";
import VelocitySparkline from "../../../components/viz/VelocitySparkline.astro";
import LanguageBars from "../../../components/viz/LanguageBars.astro";
import { t, ui } from "../../../lib/i18n.js";
import {
  getProfile,
  showHeatmap,
  showVelocity,
  showLanguages,
} from "../../../lib/data.js";
import type { ProjectData } from "../../../lib/data.js";

interface Props {
  locale: string;
  project: ProjectData;
}

const { locale, project } = Astro.props;
const profile = await getProfile();
const sl = profile.sourceLang;

const gh = project.sources.find((s) => s.type === "github");
const isPrivate = project.sources.some((s) => s.visibility === "private");
const repoUrl = gh && gh.visibility === "public" ? gh.repoUrl : undefined;

// Primary calls-to-action first: demo / store / video, then everything else.
const LINK_PRIORITY = ["demo", "store", "video"];
const linkRank = (k: string) => {
  const i = LINK_PRIORITY.indexOf(k);
  return i === -1 ? 99 : i;
};
const links = [...project.links].sort((a, b) => linkRank(a.kind) - linkRank(b.kind));

const heat = showHeatmap(project);
const vel = showVelocity(project);
const langs = showLanguages(project);
const anyViz = heat || vel || langs;

const summary = t(project.summary, locale, sl);
---

<Base
  locale={locale}
  title={project.name}
  description={summary}
  path={`/projects/${project.id}`}
  ogImage={`/og/${project.id}.png`}
>
  <article class="container page">
    <header class="tldr">
      <p class="spec-line" aria-hidden="true">
        <i class="led"></i>
        {project.id}{isPrivate && <span class="spec-priv"> · PRIVATE</span>}
      </p>
      <div class="title-row">
        <h1 class="name">{project.name}</h1>
        <CategoryBadge category={project.category} locale={locale} />
        {
          project.role && (
            <span class="chip" title={t(project.role.scope, locale, sl) || undefined}>
              {ui(`project.role.${project.role.type}`, locale)}
            </span>
          )
        }
      </div>
      {summary && <p class="summary">{summary}</p>}
      <TechStackList techStack={project.techStack} max={3} />
      <MetricChips project={project} locale={locale} />
      {
        links.length > 0 && (
          <div class="links-row">
            {links.map((l) => (
              <a
                class:list={["btn", { primary: LINK_PRIORITY.includes(l.kind) }]}
                href={l.url}
                target="_blank"
                rel="noopener"
              >
                {t(l.label, locale, sl) || l.kind}
                <span aria-hidden="true">↗</span>
              </a>
            ))}
          </div>
        )
      }
    </header>

    {isPrivate && <p class="card note">{ui("project.proprietary", locale)}</p>}

    <CaseStudy project={project} locale={locale} sourceLang={sl} />

    {
      project.highlights.length > 0 && (
        <section>
          <h2 class="section-title" data-reveal>{ui("project.highlights", locale)}</h2>
          <div class="hl-grid" data-reveal-group>
            {project.highlights.map((h) => (
              <article class="card hl" data-reveal>
                <p class="hl-text">{t(h.text, locale, sl)}</p>
                <p class="receipts">
                  {h.evidence.map((e) => (
                    <EvidenceLink
                      evidence={e}
                      repoUrl={repoUrl}
                      isPrivate={isPrivate}
                      locale={locale}
                    />
                  ))}
                </p>
              </article>
            ))}
          </div>
        </section>
      )
    }

    {
      project.timeline.length > 0 && (
        <section>
          <h2 class="section-title" data-reveal>{ui("project.timeline", locale)}</h2>
          <Timeline
            timeline={project.timeline}
            locale={locale}
            sourceLang={sl}
            repoUrl={repoUrl}
            isPrivate={isPrivate}
          />
        </section>
      )
    }

    {
      project.metrics && (
        <section>
          <h2 class="section-title" data-reveal>{ui("project.metrics", locale)}</h2>
          <div class="viz-stack">
            {langs && <LanguageBars languages={project.metrics.languages} />}
            {vel && (
              <VelocitySparkline
                commitsByDay={project.metrics.total.commitsByDay}
                locale={locale}
              />
            )}
            {heat && (
              <ContributionHeatmap
                commitsByDay={project.metrics.total.commitsByDay}
                locale={locale}
              />
            )}
            {!anyViz && <MetricChips project={project} locale={locale} />}
          </div>
        </section>
      )
    }

    {
      project.architectureDiagram && (
        <section>
          <h2 class="section-title">{ui("project.architecture", locale)}</h2>
          <figure class="window diagram">
            <figcaption class="win-bar">
              <span class="win-dots" aria-hidden="true">
                <i></i>
                <i></i>
                <i></i>
              </span>
              <span class="win-label">{project.id}</span>
            </figcaption>
            <img
              src={"/" + project.architectureDiagram}
              alt={ui("project.architecture", locale)}
              loading="lazy"
            />
          </figure>
        </section>
      )
    }

    {
      project.screenshots.length > 0 && (
        <section>
          <h2 class="section-title">{ui("project.screenshots", locale)}</h2>
          <Screenshots
            screenshots={project.screenshots}
            locale={locale}
            sourceLang={sl}
          />
        </section>
      )
    }
  </article>
</Base>

<style>
  .page {
    margin-top: var(--space-7);
    display: grid;
    gap: var(--space-8);
  }
  .tldr {
    display: grid;
    gap: var(--space-4);
  }

  /* mono spec kicker echoes the cockpit voice */
  .spec-line {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .spec-priv {
    color: var(--warn);
  }

  .title-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
  .name {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(30px, 5vw, 48px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--text);
  }
  .summary {
    margin: 0;
    font-size: var(--text-lg);
    line-height: 1.7;
    color: var(--text-dim);
    max-width: 62ch;
  }

  .links-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  /* proprietary note: a locked instrument panel */
  .note {
    margin: 0;
    padding: var(--space-3) var(--space-4);
    border-left: 3px solid var(--warn);
    background: var(--bg-overlay);
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: 0.03em;
  }

  /* evidence-linked highlight cards */
  .hl-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 26rem), 1fr));
    gap: var(--space-4);
  }
  .hl {
    padding: var(--space-4) var(--space-5);
    position: relative;
  }
  .hl::before {
    content: "";
    position: absolute;
    left: -1px;
    top: var(--space-4);
    bottom: var(--space-4);
    width: 3px;
    background: var(--accent);
    border-radius: var(--radius-sm);
  }
  .hl-text {
    margin: 0;
    line-height: 1.7;
    color: var(--text);
  }
  .receipts {
    margin: var(--space-3) 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
  }

  .viz-stack {
    display: grid;
    gap: var(--space-6);
  }

  /* window-framed architecture diagram */
  .diagram {
    margin: 0;
  }
  .diagram .win-label {
    margin-left: auto;
    color: var(--text-faint);
  }
  .diagram img {
    display: block;
    width: 100%;
    height: auto;
    background: var(--bg-deep);
  }

  @media (prefers-reduced-motion: reduce) {
    .hl::before {
      background: var(--accent);
    }
  }
</style>
