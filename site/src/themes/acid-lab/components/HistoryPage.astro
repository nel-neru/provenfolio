---
/**
 * Acid-lab cross-project history — read surface. Density-gated by
 * showHistoryPage(): until the data has depth or breadth, an honest empty
 * note plus the oldest-first project list renders instead of a chart that
 * would lie. The full view is a pure-CSS horizontal span chart over
 * projectSpans, yearly activity chips, and a tech-adoption note. Restyled as
 * a lab instrument (square bars, dotted year rails); all span math, gates,
 * and sort orders are unchanged from the structural reference.
 */
import Base from "../../../layouts/Base.astro";
import ProjectCard from "../../../components/ProjectCard.astro";
import { ui, localePath } from "../../../lib/i18n.js";
import {
  getProfile,
  getAggregates,
  getProjects,
  showHistoryPage,
} from "../../../lib/data.js";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const profile = await getProfile();
const sl = profile.sourceLang;
const defaultLocale = sl;
const aggregates = await getAggregates();
const visible = showHistoryPage(aggregates);

// Sparse branch: all projects, oldest first (still useful).
const projects = await getProjects();
const byFirstCommit = [...projects].sort((a, b) =>
  (a.metrics?.total.firstCommit ?? "9999").localeCompare(
    b.metrics?.total.firstCommit ?? "9999"
  )
);

// Full branch: span bars across the min..max commit range.
const DAY = 86_400_000;
const spans = (aggregates?.projectSpans ?? []).filter(
  (s) => s.firstCommit && s.lastCommit
);
const minT = spans.length
  ? Math.min(...spans.map((s) => Date.parse(s.firstCommit!)))
  : 0;
const maxT = spans.length
  ? Math.max(...spans.map((s) => Date.parse(s.lastCommit!)))
  : 0;
const range = Math.max(maxT - minT, DAY);

const rows = spans.map((s) => ({
  id: s.id,
  name: s.name,
  placement: s.placement,
  commits: s.commits,
  first: s.firstCommit!,
  last: s.lastCommit!,
  left: ((Date.parse(s.firstCommit!) - minT) / range) * 100,
  width: Math.max(
    ((Date.parse(s.lastCommit!) - Date.parse(s.firstCommit!)) / range) * 100,
    1.5
  ),
}));

// Year gridlines: Jan 1 of each year inside the range.
const years: Array<{ year: number; left: number }> = [];
if (spans.length) {
  for (
    let y = new Date(minT).getUTCFullYear() + 1;
    y <= new Date(maxT).getUTCFullYear();
    y++
  ) {
    const t = Date.parse(`${y}-01-01T00:00:00Z`);
    if (t >= minT && t <= maxT) years.push({ year: y, left: ((t - minT) / range) * 100 });
  }
}

const yearly = aggregates?.yearlyActivity ?? [];
// Tech adoption note, ordered by first use.
const adoption = (aggregates?.techFrequency ?? [])
  .filter((t) => t.firstUsed)
  .sort((a, b) => a.firstUsed!.localeCompare(b.firstUsed!));
---

<Base locale={locale} title={ui("history.title", locale)} path="/history">
  <div class="container page">
    <header class="page-head">
      <h1 class="page-title">{ui("history.title", locale)}</h1>
    </header>

    {
      !visible ? (
        <>
          <p class="empty-note">{ui("history.empty", locale)}</p>
          <div class="grid">
            {byFirstCommit.map((p) => (
              <ProjectCard
                project={p}
                locale={locale}
                sourceLang={sl}
                defaultLocale={defaultLocale}
              />
            ))}
          </div>
        </>
      ) : (
        <>
          <section class="block">
            <div class="span-chart">
              {years.map((y) => (
                <span
                  class="year-line"
                  style={`left:${y.left}%`}
                  aria-hidden="true"
                >
                  <span class="year-label">{y.year}</span>
                </span>
              ))}
              {rows.map((r) => (
                <div class="span-row">
                  <a
                    class="span-name"
                    href={localePath(`/projects/${r.id}`, locale, defaultLocale)}
                  >
                    {r.name}
                  </a>
                  <div class="track">
                    <span
                      class:list={["bar", `pl-${r.placement}`]}
                      style={`left:${r.left}%;width:${r.width}%`}
                      title={`${r.first} — ${r.last}`}
                    />
                  </div>
                </div>
              ))}
            </div>
          </section>

          {yearly.length > 0 && (
            <section class="block">
              <div class="year-chips">
                {yearly.map((y) => (
                  <span class="chip">
                    <b>{y.year}</b> {y.commits} {ui("metrics.commits", locale)} ·{" "}
                    {y.activeDays} {ui("metrics.activeDays", locale)}
                  </span>
                ))}
              </div>
            </section>
          )}

          {adoption.length > 0 && (
            <section class="block">
              <p class="adoption">
                {adoption.map((t, i) => (
                  <span class="adoption-item">
                    {i > 0 && <span aria-hidden="true"> · </span>}
                    {t.name}
                    <span class="since"> {t.firstUsed!.slice(0, 4)}~</span>
                  </span>
                ))}
              </p>
            </section>
          )}
        </>
      )
    }
  </div>
</Base>

<style>
  .page {
    margin-top: var(--space-7);
  }
  .page-head {
    margin-bottom: var(--space-7);
  }
  .page-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(30px, 5.5vw, 46px);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--text);
    position: relative;
    padding-bottom: var(--space-3);
  }
  .page-title::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: min(200px, 50%);
    height: 3px;
    background: linear-gradient(90deg, var(--accent) 0 44px, var(--line-strong) 44px);
  }

  .empty-note {
    color: var(--text-dim);
    margin: 0 0 var(--space-6);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.7;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-5);
  }
  .block + .block {
    margin-top: var(--space-6);
  }

  /* span chart: square lab instrument on a dotted rail */
  .span-chart {
    position: relative;
    display: grid;
    gap: var(--space-4);
    padding-block: var(--space-5) var(--space-2);
  }
  .year-line {
    position: absolute;
    top: 0;
    bottom: 0;
    border-left: 1px dotted var(--line-strong);
  }
  .year-label {
    position: absolute;
    top: -0.4rem;
    left: 0.35rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-faint);
    font-variant-numeric: tabular-nums;
  }
  .span-row {
    display: grid;
    grid-template-columns: minmax(8rem, 14rem) 1fr;
    align-items: center;
    gap: var(--space-4);
  }
  .span-name {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-dim);
    letter-spacing: 0.03em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .span-name:hover,
  .span-name:focus-visible {
    color: var(--accent);
    text-decoration: none;
  }
  .track {
    position: relative;
    height: 12px;
    background: var(--bg-deep);
    border: 1px solid var(--line);
    overflow: hidden;
  }
  .bar {
    position: absolute;
    top: 0;
    bottom: 0;
    background: var(--text-faint);
  }
  .pl-products {
    background: var(--accent);
  }
  .pl-lab {
    background: var(--decor-blue);
  }
  .pl-archive {
    background: var(--text-faint);
  }
  .year-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .adoption {
    margin: 0;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.9;
    letter-spacing: 0.03em;
  }
  .since {
    color: var(--accent);
    font-size: 0.85em;
    font-variant-numeric: tabular-nums;
  }
</style>
