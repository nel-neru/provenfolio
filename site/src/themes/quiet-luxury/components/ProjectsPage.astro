---
/**
 * Projects index — the catalogue. Placement sections in fixed order
 * (products → lab → archive), numbered like monograph chapters via the
 * shared .section-title primitive (a .folio ancestor resets the counter).
 * Products and lab get full plate cards; archive is a hairline-ruled
 * catalogue list of name + one summary line. Empty placements render nothing.
 * Structure/logic mirror the midnight ProjectsPage; only the dress changes.
 */
import Base from "../../../layouts/Base.astro";
import ProjectCard from "../../../components/ProjectCard.astro";
import { t, ui, localePath } from "../../../lib/i18n.js";
import { getProfile, getProjects, byPlacement } from "../../../lib/data.js";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const profile = await getProfile();
const sl = profile.sourceLang;
const defaultLocale = sl;
const placed = byPlacement(await getProjects());

const sections = [
  { key: "projects.products", items: placed.products },
  { key: "projects.lab", items: placed.lab },
] as const;
---

<Base locale={locale} title={ui("projects.title", locale)} path="/projects">
  <div class="container page folio">
    <header class="page-head">
      <h1 class="page-title">
        {ui("projects.title", locale)}<span class="fullstop" aria-hidden="true">.</span>
      </h1>
    </header>

    {
      sections.map(
        (s) =>
          s.items.length > 0 && (
            <section class="block">
              <h2 class="section-title" data-reveal>{ui(s.key, locale)}</h2>
              <div class="grid" data-reveal-group>
                {s.items.map((p) => (
                  <ProjectCard
                    project={p}
                    locale={locale}
                    sourceLang={sl}
                    defaultLocale={defaultLocale}
                  />
                ))}
              </div>
            </section>
          )
      )
    }

    {
      placed.archive.length > 0 && (
        <section class="block">
          <h2 class="section-title" data-reveal>{ui("projects.archive", locale)}</h2>
          <ul class="archive-list" role="list" data-reveal-group>
            {placed.archive.map((p, i) => (
              <li class="archive-item" data-reveal>
                <span class="archive-index" aria-hidden="true">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <a
                  class="archive-name"
                  href={localePath(`/projects/${p.id}`, locale, defaultLocale)}
                >
                  {p.name}
                </a>
                {t(p.summary, locale, sl) && (
                  <span class="archive-summary">
                    &mdash; {t(p.summary, locale, sl)}
                  </span>
                )}
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </div>
</Base>

<style>
  .page {
    margin-top: clamp(2.5rem, 6vh, 4rem);
    padding-bottom: 2rem;
  }
  .page-head {
    margin-bottom: var(--sec-gap);
  }
  .page-title {
    margin: 0;
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-size: var(--fs-title);
    font-weight: 400;
    letter-spacing: -0.01em;
  }
  .block + .block {
    margin-top: var(--sec-gap);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(19rem, 1fr));
    gap: 1.25rem;
  }

  /* Archive: a book's catalogue register — hairline rows, mono index,
     serif names, em-dash annotations. */
  .archive-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-bottom: 1px solid var(--line);
  }
  .archive-item {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: 0.15rem 1.25rem;
    align-items: baseline;
    border-top: 1px solid var(--line);
    padding: 0.95rem 0;
    line-height: 1.6;
  }
  .archive-index {
    grid-row: 1 / span 2;
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-size: var(--fs-mono);
    color: var(--accent);
  }
  .archive-name {
    font-family: var(--font-serif);
    font-size: 1.08rem;
    color: var(--text);
    text-decoration: none;
  }
  .archive-name:hover {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.22em;
    text-decoration-color: currentColor;
  }
  .archive-summary {
    grid-column: 2;
    font-family: var(--font-serif);
    font-size: 0.98rem;
    color: var(--text-dim);
  }

  @media (max-width: 560px) {
    .archive-item {
      grid-template-columns: 1fr;
    }
    .archive-index {
      grid-row: auto;
    }
    .archive-summary {
      grid-column: 1;
    }
  }
</style>
