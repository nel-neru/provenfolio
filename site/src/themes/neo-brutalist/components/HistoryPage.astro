---
/**
 * Cross-project history. Density-gated by showHistoryPage(): until the data
 * has time depth or breadth, an honest note (a dashed stamp) plus the project
 * list (sorted by first commit) renders instead of a bar chart that would
 * lie. The full view is a pure-CSS horizontal span chart over projectSpans
 * drawn as hard-edged ink bars, yearly activity chips, and a tech-adoption
 * note from techFrequency. All computation (spans, range, gridlines, adoption
 * ordering) is identical to midnight/HistoryPage; only the styling changes.
 */
import Base from "../../../layouts/Base.astro";
import ProjectCard from "../../../components/ProjectCard.astro";
import { ui, localePath } from "../../../lib/i18n.js";
import {
  getProfile,
  getAggregates,
  getProjects,
  showHistoryPage,
} from "../../../lib/data.js";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const profile = await getProfile();
const sl = profile.sourceLang;
const defaultLocale = sl;
const aggregates = await getAggregates();
const visible = showHistoryPage(aggregates);

// Sparse branch: all projects, oldest first (still useful).
const projects = await getProjects();
const byFirstCommit = [...projects].sort((a, b) =>
  (a.metrics?.total.firstCommit ?? "9999").localeCompare(
    b.metrics?.total.firstCommit ?? "9999"
  )
);

// Full branch: span bars across the min..max commit range.
const DAY = 86_400_000;
const spans = (aggregates?.projectSpans ?? []).filter(
  (s) => s.firstCommit && s.lastCommit
);
const minT = spans.length
  ? Math.min(...spans.map((s) => Date.parse(s.firstCommit!)))
  : 0;
const maxT = spans.length
  ? Math.max(...spans.map((s) => Date.parse(s.lastCommit!)))
  : 0;
const range = Math.max(maxT - minT, DAY);

const rows = spans.map((s) => ({
  id: s.id,
  name: s.name,
  placement: s.placement,
  commits: s.commits,
  first: s.firstCommit!,
  last: s.lastCommit!,
  left: ((Date.parse(s.firstCommit!) - minT) / range) * 100,
  width: Math.max(
    ((Date.parse(s.lastCommit!) - Date.parse(s.firstCommit!)) / range) * 100,
    1.5
  ),
}));

// Year gridlines: Jan 1 of each year inside the range.
const years: Array<{ year: number; left: number }> = [];
if (spans.length) {
  for (
    let y = new Date(minT).getUTCFullYear() + 1;
    y <= new Date(maxT).getUTCFullYear();
    y++
  ) {
    const t = Date.parse(`${y}-01-01T00:00:00Z`);
    if (t >= minT && t <= maxT)
      years.push({ year: y, left: ((t - minT) / range) * 100 });
  }
}

const yearly = aggregates?.yearlyActivity ?? [];
// Tech adoption note, ordered by first use.
const adoption = (aggregates?.techFrequency ?? [])
  .filter((t) => t.firstUsed)
  .sort((a, b) => a.firstUsed!.localeCompare(b.firstUsed!));
---

<Base locale={locale} title={ui("history.title", locale)} path="/history">
  <div class="container page">
    <header class="page-head">
      <h1 class="page-title">{ui("history.title", locale)}</h1>
    </header>

    {
      !visible ? (
        <>
          <p class="stamp stamp-dashed empty-note">
            {ui("history.empty", locale)}
          </p>
          <div class="grid">
            {byFirstCommit.map((p) => (
              <ProjectCard
                project={p}
                locale={locale}
                sourceLang={sl}
                defaultLocale={defaultLocale}
              />
            ))}
          </div>
        </>
      ) : (
        <>
          <section class="block">
            <div class="span-chart">
              {years.map((y) => (
                <span
                  class="year-line"
                  style={`left:${y.left}%`}
                  aria-hidden="true"
                >
                  <span class="year-label">{y.year}</span>
                </span>
              ))}
              {rows.map((r) => (
                <div class="span-row">
                  <a
                    class="span-name"
                    href={localePath(
                      `/projects/${r.id}`,
                      locale,
                      defaultLocale
                    )}
                  >
                    {r.name}
                  </a>
                  <div class="track">
                    <span
                      class:list={["bar", `pl-${r.placement}`]}
                      style={`left:${r.left}%;width:${r.width}%`}
                      title={`${r.first} — ${r.last}`}
                    />
                  </div>
                </div>
              ))}
            </div>
          </section>

          {yearly.length > 0 && (
            <section class="block">
              <div class="year-chips">
                {yearly.map((y) => (
                  <span class="chip">
                    <b>{y.year}</b> {y.commits} {ui("metrics.commits", locale)}{" "}
                    · {y.activeDays} {ui("metrics.activeDays", locale)}
                  </span>
                ))}
              </div>
            </section>
          )}

          {adoption.length > 0 && (
            <section class="block">
              <p class="adoption">
                {adoption.map((t, i) => (
                  <span class="adoption-item">
                    {i > 0 && <span aria-hidden="true"> · </span>}
                    {t.name}
                    <span class="since"> {t.firstUsed!.slice(0, 4)}~</span>
                  </span>
                ))}
              </p>
            </section>
          )}
        </>
      )
    }
  </div>
</Base>

<style>
  .page {
    margin-top: var(--space-8, 64px);
    margin-bottom: var(--space-8, 64px);
  }
  .page-head {
    border-bottom: 3px solid var(--line);
    padding-bottom: var(--space-4, 16px);
    margin-bottom: var(--space-7, 48px);
  }
  .page-title {
    margin: 0;
    font-size: var(--nb-fs-d3);
    line-height: 1;
  }
  .empty-note {
    display: block;
    white-space: normal;
    margin: 0 0 var(--space-7, 48px);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(300px, 100%), 1fr));
    gap: var(--space-5, 24px);
  }
  .grid :global(a.project-card) {
    box-shadow: var(--shadow-md, none);
    transition:
      transform 0.12s ease-out,
      box-shadow 0.12s ease-out;
  }
  .grid :global(a.project-card:hover),
  .grid :global(a.project-card:focus-within) {
    box-shadow: 6px 6px 0 var(--line);
  }
  .block + .block {
    margin-top: var(--space-7, 48px);
  }

  /* Span chart — hard-edged ink bars on a bordered rail. */
  .span-chart {
    position: relative;
    display: grid;
    gap: var(--space-3, 12px);
    padding-block: var(--space-6, 32px) var(--space-2, 8px);
  }
  .year-line {
    position: absolute;
    top: 0;
    bottom: 0;
    border-left: 2px dashed var(--line);
  }
  .year-label {
    position: absolute;
    top: -0.4rem;
    left: 0.35rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs, 11px);
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--text-faint);
  }
  .span-row {
    display: grid;
    grid-template-columns: minmax(8rem, 14rem) 1fr;
    align-items: center;
    gap: var(--space-4, 16px);
  }
  .span-name {
    font-family: var(--font-mono);
    font-size: var(--text-sm, 13px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text);
    text-decoration: none;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .span-name:hover,
  .span-name:focus-visible {
    text-decoration: underline;
    text-decoration-thickness: 3px;
    text-decoration-color: var(--accent);
    text-underline-offset: 3px;
  }
  .track {
    position: relative;
    height: 16px;
    border: 2px solid var(--line);
    background: var(--nb-hatch);
    overflow: hidden;
  }
  .bar {
    position: absolute;
    top: 0;
    bottom: 0;
    background: var(--text-faint);
  }
  /* Products = the shrieking accent; lab = solid ink; archive = paper block. */
  .pl-products {
    background: var(--accent);
  }
  .pl-lab {
    background: var(--line);
  }
  .pl-archive {
    background: var(--nb-gutter-ink, var(--text-faint));
  }
  .year-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2, 8px);
  }
  .adoption {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm, 13px);
    line-height: 1.9;
    color: var(--text-dim);
  }
  .since {
    color: var(--text-faint);
    font-size: 0.85em;
  }

  @media (max-width: 720px) {
    .page {
      margin-top: var(--space-7, 48px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .grid :global(a.project-card:hover),
    .grid :global(a.project-card:focus-within) {
      box-shadow: var(--shadow-md, none), inset 0 0 0 1px var(--line);
    }
  }
</style>
