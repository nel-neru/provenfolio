---
/**
 * Overview — the recruiter one-pager, restyled into the neo-brutalist system
 * but kept deliberately calm and dense: a compact masthead, then one tight
 * bordered card per non-archive project (name, category, summary, honest
 * metric chips, top-3 stack, demo link). No hero, no viz. The print
 * stylesheet is preserved and ink-friendly — the freight shadows drop, the
 * paper goes white, and everything collapses to hairline borders on ink text
 * so this page is the "hand this PDF to a recruiter" export. Data access and
 * the demo-link selection mirror midnight/OverviewPage.
 */
import Base from "../../../layouts/Base.astro";
import CategoryBadge from "../../../components/CategoryBadge.astro";
import TechStackList from "../../../components/TechStackList.astro";
import MetricChips from "../../../components/MetricChips.astro";
import { t, ui, localePath } from "../../../lib/i18n.js";
import { getProfile, getProjects } from "../../../lib/data.js";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const profile = await getProfile();
const sl = profile.sourceLang;
const defaultLocale = sl;
const projects = (await getProjects()).filter((p) => p.placement !== "archive");

const DEMO_KINDS = ["demo", "store", "video"];
const demoLink = (p: (typeof projects)[number]) =>
  p.links.find((l) => DEMO_KINDS.includes(l.kind));
---

<Base locale={locale} title={ui("overview.title", locale)} path="/overview">
  <div class="container page">
    <p class="note">{ui("overview.note", locale)}</p>

    <header class="head">
      <h1 class="name">{profile.name}</h1>
      <p class="line">
        {t(profile.role, locale, sl)}
        <span class="sep" aria-hidden="true">/</span>
        {t(profile.tagline, locale, sl)}
      </p>
      <p class="socials">
        {
          profile.socials.map((s) => (
            <a href={s.url} rel="me noopener">
              {s.platform}
            </a>
          ))
        }
        {
          profile.email && (
            <a href={`mailto:${profile.email}`}>{profile.email}</a>
          )
        }
      </p>
    </header>

    <div class="stack">
      {
        projects.map((p) => {
          const demo = demoLink(p);
          return (
            <article class="card ov-card">
              <div class="row">
                <h2 class="p-name">
                  <a
                    href={localePath(
                      `/projects/${p.id}`,
                      locale,
                      defaultLocale
                    )}
                  >
                    {p.name}
                  </a>
                </h2>
                <CategoryBadge category={p.category} locale={locale} />
                {demo && (
                  <a
                    class="demo"
                    href={demo.url}
                    target="_blank"
                    rel="noopener"
                  >
                    {t(demo.label, locale, sl) || demo.kind}
                  </a>
                )}
              </div>
              <p class="p-summary">{t(p.summary, locale, sl)}</p>
              <div class="row meta">
                <MetricChips project={p} locale={locale} />
                <TechStackList techStack={p.techStack} max={3} />
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</Base>

<style>
  .page {
    margin-top: var(--space-6, 32px);
    margin-bottom: var(--space-8, 64px);
  }
  .note {
    margin: 0 0 var(--space-5, 24px);
    font-family: var(--font-mono);
    font-size: var(--text-xs, 11px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-faint);
  }
  .head {
    border-bottom: 3px solid var(--line);
    padding-bottom: var(--space-4, 16px);
    margin-bottom: var(--space-5, 24px);
  }
  .name {
    margin: 0;
    font-size: var(--text-xl, 28px);
    line-height: 1;
  }
  .line {
    margin: var(--space-2, 8px) 0 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm, 13px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-dim);
  }
  .sep {
    margin-inline: 0.5em;
    color: var(--text-faint);
  }
  .socials {
    margin: var(--space-3, 12px) 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4, 16px);
    font-family: var(--font-mono);
    font-size: var(--text-sm, 13px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .socials a {
    color: var(--text);
  }
  .stack {
    display: grid;
    gap: var(--space-3, 12px);
  }
  .ov-card {
    padding: var(--space-4, 16px);
    display: grid;
    gap: var(--space-3, 12px);
    box-shadow: none;
  }
  .row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3, 12px);
  }
  .p-name {
    margin: 0;
    font-size: var(--text-lg, 22px);
    line-height: 1;
  }
  .p-name a {
    color: var(--text);
    text-decoration: none;
  }
  .p-name a:hover,
  .p-name a:focus-visible {
    text-decoration: underline;
    text-decoration-thickness: 3px;
    text-decoration-color: var(--accent);
    text-underline-offset: 3px;
  }
  .demo {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: var(--text-xs, 11px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-decoration: none;
    color: var(--text);
    border: 2px solid var(--line);
    background: var(--bg-raised);
    padding: 4px 10px;
  }
  .demo:hover,
  .demo:focus-visible {
    background: var(--show-accent2, var(--accent-soft));
    text-decoration: none;
  }
  .p-summary {
    margin: 0;
    color: var(--text-dim);
    line-height: 1.6;
    max-width: 70ch;
  }
  .meta {
    row-gap: var(--space-2, 8px);
  }

  /* Print: dense, ink-friendly, no freight. Global rules already hide the
     header/footer/theme-dock and set the white background; here the paper
     cards collapse to hairline borders on ink text. */
  @media print {
    .page {
      margin-top: 0;
    }
    .note {
      display: none;
    }
    .head {
      border-bottom-color: #111;
    }
    .name,
    .p-name a,
    .p-summary,
    .line {
      color: #111;
    }
    .ov-card {
      break-inside: avoid;
      border: 1px solid #ccc;
      background: #fff;
      box-shadow: none;
    }
    .socials a,
    .demo {
      color: #111;
      border-color: #999;
      background: #fff;
    }
    a {
      text-decoration: none;
    }
    .ov-card :global(.chip) {
      background: #fff;
      color: #333;
      border-color: #ccc;
      box-shadow: none;
    }
    .ov-card :global(.chip b) {
      color: #111;
    }
  }
</style>
