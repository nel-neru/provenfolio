---
/**
 * About — identity, bio, computed evidence-linked skills (chip title lists
 * the backing project ids), socials, and email, restyled into the
 * neo-brutalist system: a squared bordered avatar, a display name over a mono
 * role stamp, the bio as a reading column, skills as grouped chip rows under
 * a ruled section head, and contacts as bordered mono chips. No hand-typed
 * skill lists — everything comes from computeSkills(aggregates, profile).
 * Structure and data access mirror midnight/AboutPage.
 */
import Base from "../../../layouts/Base.astro";
import { t, ui } from "../../../lib/i18n.js";
import { getProfile, getAggregates, computeSkills } from "../../../lib/data.js";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const profile = await getProfile();
const sl = profile.sourceLang;
const aggregates = await getAggregates();

const skills = computeSkills(aggregates, profile);
const CAT_ORDER = ["language", "framework", "runtime", "infra", "tool"];
const catRank = (c: string) => {
  const i = CAT_ORDER.indexOf(c);
  return i === -1 ? 99 : i;
};
const categories = [...new Set(skills.map((s) => s.category))].sort(
  (a, b) => catRank(a) - catRank(b) || a.localeCompare(b)
);
const skillGroups = categories.map((cat) => ({
  cat,
  items: skills.filter((s) => s.category === cat),
}));

const pad3 = (n: number) => String(n).padStart(3, "0");
const role = t(profile.role, locale, sl);
---

<Base locale={locale} title={ui("about.title", locale)} path="/about">
  <div class="container page">
    <header class="who">
      {
        profile.avatar && (
          <img
            class="avatar"
            src={"/" + profile.avatar}
            alt={profile.name}
            width="96"
            height="96"
          />
        )
      }
      <div class="who-text">
        <h1 class="name">{profile.name}</h1>
        {role && <p class="role">{role}</p>}
      </div>
    </header>

    <p class="bio">{t(profile.bio, locale, sl)}</p>

    {
      skills.length > 0 && (
        <section class="block">
          <div class="section-head quiet">
            <h2 class="section-title">{ui("about.skills", locale)}</h2>
            <span class="section-count">{pad3(skills.length)}</span>
          </div>
          <div class="skill-groups">
            {skillGroups.map((g) => (
              <div class="skill-row">
                {g.items.map((s) => (
                  <span
                    class="chip"
                    title={s.projectIds.join(", ") || undefined}
                  >
                    {s.name}
                  </span>
                ))}
              </div>
            ))}
          </div>
        </section>
      )
    }

    <section class="block">
      <ul class="contact" role="list">
        {
          profile.socials.map((s) => (
            <li class="contact-item">
              <a href={s.url} rel="me noopener">
                {s.platform}
                {s.handle && <span class="handle">@{s.handle}</span>}
              </a>
            </li>
          ))
        }
        {
          profile.email && (
            <li class="contact-item">
              <a href={`mailto:${profile.email}`}>{profile.email}</a>
            </li>
          )
        }
      </ul>
    </section>
  </div>
</Base>

<style>
  .page {
    margin-top: var(--space-8, 64px);
    margin-bottom: var(--space-8, 64px);
    max-width: 54rem;
  }
  .who {
    display: flex;
    align-items: center;
    gap: var(--space-5, 24px);
  }
  .avatar {
    flex: none;
    border: 2px solid var(--line);
    border-radius: 0;
    box-shadow: var(--shadow-sm, none);
  }
  .name {
    margin: 0;
    font-size: var(--nb-fs-d3);
    line-height: 1;
  }
  .role {
    margin: var(--space-2, 8px) 0 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm, 13px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-dim);
  }
  .bio {
    margin: var(--space-7, 48px) 0 0;
    white-space: pre-line;
    line-height: 1.75;
    max-width: 65ch;
  }
  .block {
    margin-top: var(--space-8, 64px);
  }
  .skill-groups {
    display: grid;
    gap: var(--space-3, 12px);
  }
  .skill-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2, 8px);
  }
  .skill-row + .skill-row {
    padding-top: var(--space-3, 12px);
    border-top: 1px solid var(--line);
  }
  .contact {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3, 12px);
  }
  .contact-item a {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4em;
    font-family: var(--font-mono);
    font-size: var(--text-sm, 13px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-decoration: none;
    border: 2px solid var(--line);
    background: var(--bg-raised);
    color: var(--text);
    padding: 6px 14px;
    box-shadow: var(--shadow-sm, none);
    transition:
      transform 0.12s ease-out,
      box-shadow 0.12s ease-out;
  }
  .contact-item a:hover,
  .contact-item a:focus-visible {
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 var(--line);
    text-decoration: none;
  }
  .handle {
    color: var(--text-faint);
    text-transform: none;
    letter-spacing: 0.02em;
  }

  @media (max-width: 720px) {
    .page {
      margin-top: var(--space-7, 48px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-item a:hover,
    .contact-item a:focus-visible {
      transform: none;
      box-shadow: var(--shadow-sm, none), inset 0 0 0 1px var(--line);
    }
  }
</style>
