---
/**
 * Projects index — the same placement model as the default theme (products
 * -> lab -> archive, in fixed order; empty placements render nothing), set
 * as a ruled annual-report index. Products and lab are full index rows;
 * archive is a compact ruled list of name + one summary line. Data flows
 * through the shared CategoryBadge / MetricChips primitives.
 */
import Base from "../../../layouts/Base.astro";
import CategoryBadge from "../../../components/CategoryBadge.astro";
import MetricChips from "../../../components/MetricChips.astro";
import { t, ui, localePath } from "../../../lib/i18n.js";
import { getProfile, getProjects, byPlacement } from "../../../lib/data.js";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const profile = await getProfile();
const sl = profile.sourceLang;
const defaultLocale = sl;
const placed = byPlacement(await getProjects());

const sections = [
  { key: "projects.products", items: placed.products },
  { key: "projects.lab", items: placed.lab },
] as const;

const pad2 = (n: number) => String(n).padStart(2, "0");
---

<Base locale={locale} title={ui("projects.title", locale)} path="/projects">
  <div class="container">
    <header class="pagehead">
      <h1>{ui("projects.title", locale)}</h1>
    </header>

    {
      sections.map(
        (s) =>
          s.items.length > 0 && (
            <section class="section">
              <h2 class="section-title">{ui(s.key, locale)}</h2>
              {s.items.map((p, i) => {
                const summary = t(p.summary, locale, sl);
                return (
                  <a class="row" href={localePath(`/projects/${p.id}`, locale, defaultLocale)}>
                    <span class="no">&#8470;&nbsp;{pad2(i + 1)}</span>
                    <span>
                      <span class="row-title">
                        <span class="t">{p.name}</span>
                        <span class="arrow" aria-hidden="true">&#8594;</span>
                      </span>
                      {summary && <p class="sum">{summary}</p>}
                    </span>
                    <span class="row-meta">
                      <CategoryBadge category={p.category} locale={locale} />
                      <MetricChips project={p} locale={locale} />
                    </span>
                  </a>
                );
              })}
            </section>
          )
      )
    }

    {
      placed.archive.length > 0 && (
        <section class="section">
          <h2 class="section-title">{ui("projects.archive", locale)}</h2>
          <ul class="archive" role="list">
            {placed.archive.map((p) => {
              const summary = t(p.summary, locale, sl);
              return (
                <li class="archive-item">
                  <a class="archive-name u-sweep" href={localePath(`/projects/${p.id}`, locale, defaultLocale)}>
                    {p.name}
                  </a>
                  {summary && <span class="archive-sum">&#8202;&#8212;&#8202;{summary}</span>}
                </li>
              );
            })}
          </ul>
        </section>
      )
    }
  </div>
</Base>

<style>
  .archive {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .archive-item {
    display: flex;
    align-items: baseline;
    gap: 4px;
    padding: 14px 0;
    border-bottom: 1px solid var(--line);
    line-height: 1.5;
  }
  .archive-item:first-child {
    border-top: 1px solid var(--line);
  }
  .archive-name {
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--text);
    flex: none;
  }
  .archive-sum {
    color: var(--text-dim);
    font-size: var(--fs-note);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>
