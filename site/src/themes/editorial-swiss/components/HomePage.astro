---
/**
 * Home — the showcase surface set as an annual-report cover: a typographic
 * hero under a single Swiss-red rule, the activity figure (Fig. 00), the
 * work index as ruled rows (not cards), and the computed skill set. No 3D
 * hero and no kinetic layer: the composed page IS the design (styles.css
 * pins the static state). Data logic mirrors the default theme; every value
 * comes from the owner's profile/aggregates.
 */
import Base from "../../../layouts/Base.astro";
import CategoryBadge from "../../../components/CategoryBadge.astro";
import MetricChips from "../../../components/MetricChips.astro";
import { t, ui, localePath } from "../../../lib/i18n.js";
import { getProfile, getAggregates, getFeatured, computeSkills } from "../../../lib/data.js";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const profile = await getProfile();
const sl = profile.sourceLang;
const defaultLocale = sl;
const aggregates = await getAggregates();
const featured = await getFeatured();

const skills = computeSkills(aggregates, profile);
// Group chips by category, language/framework first (same order as default).
const CAT_ORDER = ["language", "framework", "runtime", "infra", "tool"];
const catRank = (c: string) => {
  const i = CAT_ORDER.indexOf(c);
  return i === -1 ? 99 : i;
};
const categories = [...new Set(skills.map((s) => s.category))].sort(
  (a, b) => catRank(a) - catRank(b) || a.localeCompare(b)
);
const skillGroups = categories.map((cat) => ({
  cat,
  items: skills.filter((s) => s.category === cat),
}));

// Fig. 00 — an activity strip built purely from script-produced totals.
const fmt = (n: number) => n.toLocaleString("en-US");
const stats = aggregates
  ? [
      { value: fmt(aggregates.totals.commits), label: ui("metrics.commits", locale) },
      { value: fmt(aggregates.totals.activeDays), label: ui("metrics.activeDays", locale) },
      { value: fmt(aggregates.totals.projects), label: ui("nav.projects", locale) },
      { value: fmt(aggregates.techFrequency.length), label: ui("home.skills", locale) },
    ]
  : [];
const showStats = !!aggregates && aggregates.totals.commits > 0;

const pad2 = (n: number) => String(n).padStart(2, "0");
---

<Base locale={locale} path="/" ogImage="/og/profile.png" surface="showcase">
  <section class="hero container" id="hero">
    <div class="hero-rule" aria-hidden="true"></div>
    <h1 class="hero-name">{profile.name}</h1>
    <p class="hero-line">
      {t(profile.role, locale, sl)}
      <span class="sep" aria-hidden="true">&middot;</span>
      {t(profile.tagline, locale, sl)}
    </p>
    {
      profile.socials.length > 0 && (
        <div class="hero-socials">
          {profile.socials.map((s) => (
            <a class="social" href={s.url} rel="me noopener">
              {s.platform}
              <span class="arr" aria-hidden="true">&#8202;&#8599;</span>
            </a>
          ))}
        </div>
      )
    }
  </section>

  {
    showStats && (
      <section class="container">
        <figure class="fig bare">
          <div class="stats">
            {stats.map((s) => (
              <div class="stat">
                <b class="mono">{s.value}</b>
                <span class="micro">{s.label}</span>
              </div>
            ))}
          </div>
          <figcaption class="figcap micro">{ui("metrics.activity", locale)}</figcaption>
        </figure>
      </section>
    )
  }

  {
    featured.length > 0 && (
      <section class="section container" id="work">
        <h2 class="section-title">{ui("home.featured", locale)}</h2>
        {featured.map((p, i) => {
          const summary = t(p.summary, locale, sl);
          return (
            <a class="row" href={localePath(`/projects/${p.id}`, locale, defaultLocale)}>
              <span class="no">&#8470;&nbsp;{pad2(i + 1)}</span>
              <span>
                <span class="row-title">
                  <span class="t">{p.name}</span>
                  <span class="arrow" aria-hidden="true">&#8594;</span>
                </span>
                {summary && <p class="sum">{summary}</p>}
              </span>
              <span class="row-meta">
                <CategoryBadge category={p.category} locale={locale} />
                <MetricChips project={p} locale={locale} />
              </span>
            </a>
          );
        })}
        <p class="index-all">
          <a class="micro u-sweep" href={localePath("/projects", locale, defaultLocale)}>
            {ui("home.viewAll", locale)} <span aria-hidden="true">&#8594;</span>
          </a>
        </p>
      </section>
    )
  }

  {
    skills.length > 0 && (
      <section class="section container" id="skills">
        <h2 class="section-title">{ui("home.skills", locale)}</h2>
        <div class="skill-groups">
          {skillGroups.map((g) => (
            <div class="skill-row">
              {g.items.map((s) => (
                <span class="chip" title={s.projectIds.join(", ") || undefined}>
                  {s.name}
                </span>
              ))}
            </div>
          ))}
        </div>
      </section>
    )
  }
</Base>

<style>
  .hero {
    padding-block: clamp(72px, 11vw, 150px) clamp(64px, 9vw, 120px);
  }
  .hero-rule {
    width: 88px;
    height: 4px;
    background: var(--show-accent2, var(--accent));
    margin-bottom: clamp(24px, 3.5vw, 44px);
  }
  .hero-name {
    margin: 0;
    font-family: var(--font-display, var(--font-sans));
    font-size: var(--show-hero-scale, clamp(3.5rem, 10vw, 8.5rem));
    font-weight: 600;
    line-height: 0.98;
    letter-spacing: -0.03em;
  }
  .hero-line {
    margin: clamp(20px, 3vw, 36px) 0 0;
    font-size: var(--fs-lead);
    max-width: 40ch;
  }
  .hero-line .sep {
    color: var(--text-faint);
    margin-inline: 0.55em;
  }
  .hero-socials {
    margin-top: clamp(28px, 4vw, 48px);
    display: flex;
    flex-wrap: wrap;
    gap: 36px;
  }
  .social {
    font: 500 var(--fs-meta) / 1 var(--font-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding-bottom: 4px;
    border-bottom: 1px solid var(--text);
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }
  .social:hover,
  .social:focus-visible {
    color: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }
  .social .arr {
    color: var(--text-faint);
    transition: color 0.2s ease;
  }
  .social:hover .arr,
  .social:focus-visible .arr {
    color: var(--accent);
  }

  .index-all {
    margin: clamp(20px, 3vw, 32px) 0 0;
  }

  .skill-groups {
    display: grid;
    gap: 0;
  }
  .skill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: clamp(16px, 2.4vw, 24px) 0;
    border-bottom: 1px solid var(--line);
  }
  .skill-row:first-child {
    border-top: 1px solid var(--line);
  }

  @media (prefers-reduced-motion: reduce) {
    .social {
      transition: none;
    }
  }
</style>
