---
/**
 * The case-study page — the dossier itself. tl;dr header (mono display
 * name with a static caret echo + a pre-printed oscilloscope trace), then
 * the templated case study, evidence-linked highlights, turning-point
 * timeline, density-gated metrics viz (never an empty box: the honest chip
 * row renders when no viz qualifies), architecture diagram, and shots. The
 * shared components carry the evidence contract; the theme only styles them.
 * Data logic is identical to every theme.
 */
import Base from "../../../layouts/Base.astro";
import CategoryBadge from "../../../components/CategoryBadge.astro";
import TechStackList from "../../../components/TechStackList.astro";
import MetricChips from "../../../components/MetricChips.astro";
import EvidenceLink from "../../../components/EvidenceLink.astro";
import CaseStudy from "../../../components/CaseStudy.astro";
import Screenshots from "../../../components/Screenshots.astro";
import Timeline from "../../../components/viz/Timeline.astro";
import ContributionHeatmap from "../../../components/viz/ContributionHeatmap.astro";
import VelocitySparkline from "../../../components/viz/VelocitySparkline.astro";
import LanguageBars from "../../../components/viz/LanguageBars.astro";
import { t, ui } from "../../../lib/i18n.js";
import {
  getProfile,
  showHeatmap,
  showVelocity,
  showLanguages,
} from "../../../lib/data.js";
import type { ProjectData } from "../../../lib/data.js";

interface Props {
  locale: string;
  project: ProjectData;
}

const { locale, project } = Astro.props;
const profile = await getProfile();
const sl = profile.sourceLang;

const gh = project.sources.find((s) => s.type === "github");
const isPrivate = project.sources.some((s) => s.visibility === "private");
const repoUrl = gh && gh.visibility === "public" ? gh.repoUrl : undefined;

// Primary calls-to-action first: demo / store / video, then everything else.
const LINK_PRIORITY = ["demo", "store", "video"];
const linkRank = (k: string) => {
  const i = LINK_PRIORITY.indexOf(k);
  return i === -1 ? 99 : i;
};
const links = [...project.links].sort((a, b) => linkRank(a.kind) - linkRank(b.kind));

const heat = showHeatmap(project);
const vel = showVelocity(project);
const langs = showLanguages(project);
const anyViz = heat || vel || langs;

const summary = t(project.summary, locale, sl);

// Decorative oscilloscope geometry (not owner data), pre-printed static.
const TRACE =
  "0,52 90,52 120,50 160,54 220,52 260,20 300,66 340,36 380,52 470,52 520,48 560,55 640,52 700,14 740,68 790,42 830,52 940,52 990,49 1030,54 1090,52 1140,30 1170,58 1200,52";
---

<Base
  locale={locale}
  title={project.name}
  description={summary}
  path={`/projects/${project.id}`}
  ogImage={`/og/${project.id}.png`}
>
  <article class="container page">
    <header class="tldr">
      <div class="title-row">
        <h1 class="name">{project.name}<span class="caret caret--static" aria-hidden="true">▉</span></h1>
        <CategoryBadge category={project.category} locale={locale} />
        {
          project.role && (
            <span class="chip" title={t(project.role.scope, locale, sl) || undefined}>
              {ui(`project.role.${project.role.type}`, locale)}
            </span>
          )
        }
      </div>
      {summary && <p class="summary">{summary}</p>}
      <TechStackList techStack={project.techStack} max={3} />
      <MetricChips project={project} locale={locale} />
      {
        links.length > 0 && (
          <div class="links-row">
            {links.map((l) => (
              <a
                class:list={["btn", { primary: LINK_PRIORITY.includes(l.kind) }]}
                href={l.url}
                target="_blank"
                rel="noopener"
              >
                {t(l.label, locale, sl) || l.kind}
                <span class="ext" aria-hidden="true"> ↗</span>
              </a>
            ))}
          </div>
        )
      }

      <svg
        class="trace trace--static"
        viewBox="0 0 1200 72"
        preserveAspectRatio="none"
        aria-hidden="true"
      >
        <polyline points={TRACE}></polyline>
      </svg>
    </header>

    {isPrivate && <p class="card note">{ui("project.proprietary", locale)}</p>}

    <CaseStudy project={project} locale={locale} sourceLang={sl} />

    {
      project.highlights.length > 0 && (
        <section>
          <h2 class="section-title">{ui("project.highlights", locale)}</h2>
          <div class="hl-grid">
            {project.highlights.map((h) => (
              <article class="card hl">
                <p class="hl-text">{t(h.text, locale, sl)}</p>
                <p class="receipts">
                  {h.evidence.map((e) => (
                    <EvidenceLink
                      evidence={e}
                      repoUrl={repoUrl}
                      sourceCommit={gh?.sourceCommit}
                      isPrivate={isPrivate}
                      locale={locale}
                    />
                  ))}
                </p>
              </article>
            ))}
          </div>
        </section>
      )
    }

    {
      project.timeline.length > 0 && (
        <section>
          <h2 class="section-title">{ui("project.timeline", locale)}</h2>
          <Timeline
            timeline={project.timeline}
            locale={locale}
            sourceLang={sl}
            repoUrl={repoUrl}
            sourceCommit={gh?.sourceCommit}
            isPrivate={isPrivate}
          />
        </section>
      )
    }

    {
      project.metrics && (
        <section>
          <h2 class="section-title">{ui("project.metrics", locale)}</h2>
          <div class="viz-stack">
            {langs && <LanguageBars languages={project.metrics.languages} />}
            {vel && (
              <VelocitySparkline
                commitsByDay={project.metrics.total.commitsByDay}
                locale={locale}
              />
            )}
            {heat && (
              <ContributionHeatmap
                commitsByDay={project.metrics.total.commitsByDay}
                locale={locale}
              />
            )}
            {!anyViz && <MetricChips project={project} locale={locale} />}
          </div>
        </section>
      )
    }

    {
      project.architectureDiagram && (
        <section>
          <h2 class="section-title">{ui("project.architecture", locale)}</h2>
          <figure class="card diagram">
            <img
              src={"/" + project.architectureDiagram}
              alt={ui("project.architecture", locale)}
              loading="lazy"
            />
          </figure>
        </section>
      )
    }

    {
      project.screenshots.length > 0 && (
        <section>
          <h2 class="section-title">{ui("project.screenshots", locale)}</h2>
          <Screenshots
            screenshots={project.screenshots}
            locale={locale}
            sourceLang={sl}
          />
        </section>
      )
    }
  </article>
</Base>

<style>
  .page {
    margin-top: var(--space-7, 48px);
    display: grid;
    gap: var(--space-7, 48px);
  }
  .tldr {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: var(--space-4, 16px);
    padding-bottom: var(--space-7, 48px);
  }
  .title-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3, 12px);
  }
  .name {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4.5vw, 2.6rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--text);
  }
  .summary {
    margin: 0;
    font-size: var(--text-lg, 22px);
    line-height: 1.55;
    color: var(--text);
    max-width: 60ch;
  }
  .links-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3, 12px);
  }
  .note {
    margin: 0;
    padding: var(--space-3, 12px) var(--space-4, 16px);
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: var(--text-sm, 14px);
  }
  .hl-grid {
    display: grid;
    gap: var(--space-3, 12px);
  }
  .hl {
    padding: var(--space-4, 16px) var(--space-5, 24px);
  }
  .hl-text {
    margin: 0;
    line-height: 1.7;
  }
  .receipts {
    margin: var(--space-3, 12px) 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2, 8px);
  }
  .viz-stack {
    display: grid;
    gap: var(--space-6, 32px);
  }
  .diagram {
    margin: 0;
    padding: var(--space-4, 16px);
  }
  .diagram img {
    display: block;
    width: 100%;
    height: auto;
  }
</style>
