---
/**
 * Overview — the recruiter one-pager. Compact header, then one tight card
 * per non-archive project: name, category, summary, honest metric chips,
 * top-3 stack, demo link. No hero, no viz; print-friendly on purpose (the
 * "hand this PDF to a recruiter" page). Data logic is identical to every
 * theme; the look is the forensic mono ledger, and it stays ink-safe.
 */
import Base from "../../../layouts/Base.astro";
import CategoryBadge from "../../../components/CategoryBadge.astro";
import TechStackList from "../../../components/TechStackList.astro";
import MetricChips from "../../../components/MetricChips.astro";
import { t, ui, localePath } from "../../../lib/i18n.js";
import { getProfile, getProjects } from "../../../lib/data.js";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const profile = await getProfile();
const sl = profile.sourceLang;
const defaultLocale = sl;
const projects = (await getProjects()).filter((p) => p.placement !== "archive");

const DEMO_KINDS = ["demo", "store", "video"];
const demoLink = (p: (typeof projects)[number]) =>
  p.links.find((l) => DEMO_KINDS.includes(l.kind));
---

<Base locale={locale} title={ui("overview.title", locale)} path="/overview">
  <div class="container page">
    <p class="note">{ui("overview.note", locale)}</p>

    <header class="head">
      <h1 class="name">{profile.name}</h1>
      <p class="line">
        {t(profile.role, locale, sl)}
        <span class="sep" aria-hidden="true">•</span>
        {t(profile.tagline, locale, sl)}
      </p>
      <p class="socials">
        {
          profile.socials.map((s) => (
            <a href={s.url} rel="me noopener">
              {s.platform}
            </a>
          ))
        }
        {profile.email && <a href={`mailto:${profile.email}`}>{profile.email}</a>}
      </p>
    </header>

    <div class="stack">
      {
        projects.map((p) => {
          const demo = demoLink(p);
          return (
            <article class="card ov-card">
              <div class="row">
                <h2 class="p-name">
                  <a href={localePath(`/projects/${p.id}`, locale, defaultLocale)}>
                    {p.name}
                  </a>
                </h2>
                <CategoryBadge category={p.category} locale={locale} />
                {demo && (
                  <a class="demo" href={demo.url} target="_blank" rel="noopener">
                    {t(demo.label, locale, sl) || demo.kind}
                  </a>
                )}
              </div>
              <p class="p-summary">{t(p.summary, locale, sl)}</p>
              <div class="row meta">
                <MetricChips project={p} locale={locale} />
                <TechStackList techStack={p.techStack} max={3} />
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</Base>

<style>
  .page {
    margin-top: var(--space-6, 32px);
  }
  .note {
    margin: 0 0 var(--space-5, 24px);
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: var(--text-xs, 12px);
    letter-spacing: 0.06em;
  }
  .head {
    margin-bottom: var(--space-6, 32px);
  }
  .name {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-xl, 28px);
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .line {
    margin: var(--space-1, 4px) 0 0;
    color: var(--text-dim);
    font-size: var(--text-sm, 14px);
  }
  .sep {
    margin-inline: 0.4em;
    color: var(--text-faint);
  }
  .socials {
    margin: var(--space-3, 12px) 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4, 16px);
    font-family: var(--font-mono);
    font-size: var(--text-sm, 14px);
  }
  .stack {
    display: grid;
    gap: var(--space-3, 12px);
  }
  .ov-card {
    padding: var(--space-4, 16px);
    display: grid;
    gap: var(--space-2, 8px);
  }
  .row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3, 12px);
  }
  .p-name {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-base, 16px);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .p-name a {
    color: var(--text);
  }
  .p-name a:hover {
    color: var(--accent);
    text-decoration: none;
  }
  .demo {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: var(--text-xs, 12px);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: 1px solid var(--viz-1);
    border-radius: var(--radius-sm, 0);
    padding: 2px var(--space-3, 12px);
    color: var(--accent);
  }
  .demo:hover {
    text-decoration: none;
    border-color: var(--accent);
    background: var(--accent-soft);
  }
  .p-summary {
    margin: 0;
    color: var(--text-dim);
    font-size: var(--text-sm, 14px);
    line-height: 1.6;
  }
  .meta {
    row-gap: var(--space-2, 8px);
  }

  /* Print: dense, ink-friendly, no decoration (the theme's global print
     rules already set a white background and hide the site chrome). */
  @media print {
    .page {
      margin-top: 0;
    }
    .note {
      display: none;
    }
    .ov-card {
      break-inside: avoid;
      border: 1px solid #ccc;
      background: #fff;
    }
    .p-name a,
    .p-summary,
    .line,
    .name {
      color: #111;
    }
    .socials a,
    .demo {
      color: #111;
      border-color: #999;
    }
    a {
      text-decoration: none;
    }
    .ov-card :global(.chip) {
      background: #fff;
      color: #333;
      border-color: #ccc;
    }
    .ov-card :global(.chip b) {
      color: #111;
    }
  }
</style>
